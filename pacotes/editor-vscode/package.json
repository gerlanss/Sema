{
  "name": "sema-language-tools",
  "displayName": "Sema Language Tools",
  "description": "Extensao oficial do VS Code para a Sema, com diagnosticos semanticos, contexto de projeto, snippets de persistencia vendor-first e integracao com a CLI IA-first.",
  "version": "1.5.7",
  "publisher": "OtimiTare",
  "private": true,
  "icon": "logo.png",
  "license": "MIT",
  "keywords": [
    "sema",
    "dsl",
    "protocol",
    "governance",
    "backend",
    "database",
    "semantica",
    "ia",
    "contracts",
    "lsp",
    "postgresql",
    "mongodb",
    "redis"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/gerlanss/Sema.git"
  },
  "homepage": "https://github.com/gerlanss/Sema",
  "bugs": {
    "url": "https://github.com/gerlanss/Sema/issues"
  },
  "engines": {
    "vscode": "^1.96.0"
  },
  "categories": [
    "Programming Languages",
    "Formatters"
  ],
  "galleryBanner": {
    "color": "#0b1220",
    "theme": "dark"
  },
  "extensionKind": [
    "workspace"
  ],
  "activationEvents": [
    "onLanguage:sema",
    "onView:semaSidebar"
  ],
  "main": "./extension.js",
  "contributes": {
    "languages": [
      {
        "id": "sema",
        "aliases": [
          "Sema",
          "sema"
        ],
        "extensions": [
          ".sema"
        ],
        "configuration": "./language-configuration.json"
      }
    ],
    "grammars": [
      {
        "language": "sema",
        "scopeName": "source.sema",
        "path": "./syntaxes/sema.tmLanguage.json"
      }
    ],
    "snippets": [
      {
        "language": "sema",
        "path": "./snippets/sema.code-snippets"
      }
    ],
    "commands": [
      {
        "command": "sema.formatarDocumento",
        "title": "Sema: Formatar Documento"
      },
      {
        "command": "sema.reiniciarServidor",
        "title": "Sema: Reiniciar Servidor de Linguagem"
      },
      {
        "command": "sema.abrirStarterIa",
        "title": "Sema: Abrir Starter IA"
      },
      {
        "command": "sema.abrirPromptIa",
        "title": "Sema: Abrir Prompt IA"
      },
      {
        "command": "sema.copiarPromptIa",
        "title": "Sema: Copiar Prompt IA"
      },
      {
        "command": "sema.abrirPromptCurtoAlvoAtual",
        "title": "Sema: Abrir Prompt Curto do Alvo Atual"
      },
      {
        "command": "sema.abrirResumoAlvoAtual",
        "title": "Sema: Abrir Resumo do Alvo Atual"
      },
      {
        "command": "sema.abrirDriftAlvoAtual",
        "title": "Sema: Medir Drift do Alvo Atual"
      },
      {
        "command": "sema.prepararContextoIaProjeto",
        "title": "Sema: Preparar Contexto IA do Projeto"
      },
      {
        "command": "sema.gerarContextoIaAlvoAtual",
        "title": "Sema: Atualizar Contexto Detalhado do Alvo Atual"
      },
      {
        "command": "sema.sincronizarEntrypointsIaProjeto",
        "title": "Sema: Sincronizar EntryPoints IA do Projeto"
      },
      {
        "command": "sema.diagnosticarCli",
        "title": "Sema: Diagnosticar CLI"
      },
      {
        "command": "sema.configurarIa",
        "title": "Sema: Configurar IA no Projeto"
      },
      {
        "command": "sema.configurarIaClaude",
        "title": "Sema: Configurar Claude Code"
      },
      {
        "command": "sema.configurarIaCursor",
        "title": "Sema: Configurar Cursor"
      },
      {
        "command": "sema.configurarIaWindsurf",
        "title": "Sema: Configurar Windsurf"
      },
      {
        "command": "sema.configurarIaCline",
        "title": "Sema: Configurar Cline"
      },
      {
        "command": "sema.configurarIaCopilot",
        "title": "Sema: Configurar GitHub Copilot"
      },
      {
        "command": "sema.configurarIaOpenCode",
        "title": "Sema: Configurar OpenCode"
      }
    ],
    "viewsContainers": {
      "activitybar": [
        {
          "id": "sema",
          "title": "Sema",
          "icon": "logo.png"
        }
      ]
    },
    "views": {
      "sema": [
        {
          "type": "webview",
          "id": "semaSidebar",
          "name": "Painel de Controle"
        }
      ]
    },
    "configuration": {
      "title": "Sema",
      "properties": {
        "sema.cliPath": {
          "type": "string",
          "default": "",
          "description": "Caminho opcional para o executavel da CLI da Sema. Quando preenchido, a extensao usa esse caminho como fonte unica. Quando vazio, ela tenta primeiro a CLI instalada no usuario e so depois o bin local do projeto."
        },
        "sema.diagnosticosAoDigitar": {
          "type": "boolean",
          "default": true,
          "description": "Quando ativo, o servidor de linguagem recalcula diagnosticos semanticos durante a digitacao."
        }
      }
    }
  },
  "dependencies": {
    "@sema/nucleo": "file:../nucleo",
    "vscode-languageclient": "^9.0.1",
    "vscode-languageserver": "^9.0.1",
    "vscode-languageserver-textdocument": "^1.0.11"
  }
}

{
  "name": "sema-language-tools",
  "displayName": "Sema Language Tools",
  "description": "Suporte de editor para o protocolo Sema, com diagnosticos, hover, formatacao, snippets e LSP inicial.",
  "version": "0.8.4",
  "publisher": "OtimiTare",
  "private": true,
  "icon": "logo.png",
  "license": "MIT",
  "keywords": [
    "sema",
    "dsl",
    "protocol",
    "governance",
    "backend",
    "semantica",
    "ia",
    "contracts",
    "lsp"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/gerlanss/Sema.git"
  },
  "homepage": "https://github.com/gerlanss/Sema",
  "bugs": {
    "url": "https://github.com/gerlanss/Sema/issues"
  },
  "engines": {
    "vscode": "^1.96.0"
  },
  "categories": [
    "Programming Languages",
    "Formatters"
  ],
  "galleryBanner": {
    "color": "#0b1220",
    "theme": "dark"
  },
  "extensionKind": [
    "workspace"
  ],
  "activationEvents": [
    "onLanguage:sema",
    "onCommand:sema.formatarDocumento",
    "onCommand:sema.reiniciarServidor"
  ],
  "main": "./extension.js",
  "contributes": {
    "languages": [
      {
        "id": "sema",
        "aliases": [
          "Sema",
          "sema"
        ],
        "extensions": [
          ".sema"
        ],
        "configuration": "./language-configuration.json"
      }
    ],
    "grammars": [
      {
        "language": "sema",
        "scopeName": "source.sema",
        "path": "./syntaxes/sema.tmLanguage.json"
      }
    ],
    "snippets": [
      {
        "language": "sema",
        "path": "./snippets/sema.code-snippets"
      }
    ],
    "commands": [
      {
        "command": "sema.formatarDocumento",
        "title": "Sema: Formatar Documento"
      },
      {
        "command": "sema.reiniciarServidor",
        "title": "Sema: Reiniciar Servidor de Linguagem"
      }
    ],
    "configuration": {
      "title": "Sema",
      "properties": {
        "sema.cliPath": {
          "type": "string",
          "default": "",
          "description": "Caminho opcional para o executavel da CLI da Sema. Quando vazio, a extensao tenta usar o bin `sema`, depois o bin local do projeto e por fim a CLI do proprio repositorio."
        },
        "sema.diagnosticosAoDigitar": {
          "type": "boolean",
          "default": true,
          "description": "Quando ativo, o servidor de linguagem recalcula diagnosticos semanticos durante a digitacao."
        }
      }
    }
  },
  "dependencies": {
    "@sema/nucleo": "file:../nucleo",
    "vscode-languageclient": "^9.0.1",
    "vscode-languageserver": "^9.0.1",
    "vscode-languageserver-textdocument": "^1.0.11"
  }
}
